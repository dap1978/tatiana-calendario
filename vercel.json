{
  "version": 2,
  "builds": [
    { "src": "api/slack.js", "use": "@vercel/node" },
    { "src": "api/calendar.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/slack", "dest": "/api/slack.js" },
    { "src": "/api/calendar", "dest": "/api/calendar.js" },
    { "src": "/ver", "dest": "/ver.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
